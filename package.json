{
    "name": "chromium-profile-manager",
    "version": "1.0.0",
    "description": "Automated Chromium Profile Manager with Extension Support",
    "main": "dist/main.js",
    "scripts": {
        "dev:frontend": "vite",
        "build:frontend": "vite build",
        "dev:backend": "tsx watch src/main.ts",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
        "build": "tsc && npm run build:frontend",
        "start": "npm run build && node dist/main.js",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "keywords": [
        "chromium",
        "playwright",
        "profile-manager",
        "automation"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "better-sqlite3": "^12.11.1",
        "cloakbrowser": "^0.3.31",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "playwright": "^1.40.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "uuid": "^9.0.1",
        "winston": "^3.11.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/uuid": "^9.0.7",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.13.0",
        "@typescript-eslint/parser": "^6.13.0",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^10.0.3",
        "eslint": "^8.54.0",
        "prettier": "^3.1.0",
        "rimraf": "^5.0.5",
        "tsx": "^4.7.0",
        "typescript": "^5.3.2",
        "vite": "^8.0.16"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
